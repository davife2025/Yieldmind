# ─────────────────────────────────────────────
# YieldMind — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MANTLE NETWORK
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.testnet.mantle.xyz
NEXT_PUBLIC_CHAIN_ID=5003
# Mainnet: https://rpc.mantle.xyz | Chain ID: 5000

# BYBIT API (server-side only — never expose to client)
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-api-secret
BYBIT_BASE_URL=https://api-testnet.bybit.com
# Mainnet: https://api.bybit.com

# ANTHROPIC (AI Agent reasoning)
ANTHROPIC_API_KEY=your-anthropic-api-key

# SMART CONTRACTS
AGENT_IDENTITY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=your-deployer-private-key

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YieldMind
DECISION_LEDGER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
